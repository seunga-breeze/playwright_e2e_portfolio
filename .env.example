# Environment Variables Example
# Copy this file to .env.local and fill in your actual values

# Country-specific Login Credentials
# Australia (AU)
AU_LOGIN_ID=your_au_username
AU_LOGIN_PW=your_au_password

# United Kingdom (UK)
UK_LOGIN_ID=your_uk_username
UK_LOGIN_PW=your_uk_password

# API Configuration (if needed)
API_URL=https://api.example.com
API_KEY=your_api_key_here

# Database Configuration (if needed)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=test_db
DB_USER=db_user
DB_PASSWORD=db_password
